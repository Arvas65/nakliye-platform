{
  "name": "nakliye-platform",
  "version": "2.0.0",
  "private": true,
  "description": "Nakliye Platformu — yük sahipleri ile nakliyecileri buluşturan modern pazaryeri",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d postgres redis",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:migrate": "pnpm --filter @nakliye/api prisma:migrate",
    "db:studio": "pnpm --filter @nakliye/api prisma:studio",
    "db:seed": "pnpm --filter @nakliye/api prisma:seed",
    "db:reset": "docker compose -f infra/docker/docker-compose.yml down -v && pnpm db:up",
    "setup": "pnpm install && pnpm db:up && timeout /t 5 && pnpm db:migrate && pnpm db:seed",
    "reset": "pnpm db:reset && timeout /t 5 && pnpm db:migrate && pnpm db:seed",
    "fresh": "pnpm clean && pnpm setup",
    "smoke": "node scripts/smoke-test.mjs",
    "prepare": "node scripts/setup-husky.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
