# ==========================================
# Nakliye Platformu — Environment Variables
# Bu dosyayı .env olarak kopyala ve doldur
# ==========================================

# ---- Database ----
DATABASE_URL="postgresql://nakliye:nakliye_dev@localhost:5432/nakliye?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- API ----
API_PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000

# ---- Auth ----
# Üretim için openssl rand -base64 64 ile yeni secret oluştur
JWT_ACCESS_SECRET="dev_access_secret_change_in_prod_min_32_chars"
JWT_REFRESH_SECRET="dev_refresh_secret_change_in_prod_min_32_chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- OAuth (opsiyonel) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=

# ---- Stripe (Escrow ödeme) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM="Nakliye Platformu <no-reply@nakliyeplatform.com>"

# ---- SMS / OTP (Twilio veya Netgsm) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---- Storage (Cloudflare R2) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nakliye-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ---- Map (Mapbox) ----
MAPBOX_TOKEN=pk.eyJ...

# ---- Push (Firebase) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---- Observability ----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=debug

# ---- Frontend (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
